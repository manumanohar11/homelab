# ~/media-stack/.env.example
# Copy this file to .env and fill in your values
# Command: cp .env.example .env

# =============================================================================
# CORE SETTINGS
# =============================================================================

# User/Group IDs - Run 'id' to find your values
PUID=1000
PGID=1000

# Timezone - Find yours at https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Domain name for service URLs, Pangolin labels, and any optional reverse proxy rules
DOMAIN_NAME=example.com

# Current LAN IP or hostname for services that need to advertise or trust direct local access
LOCAL_LAN_IP=192.168.1.10

# =============================================================================
# DIRECTORY PATHS
# =============================================================================

# Base directory for this docker project (where docker-compose.yml lives)
# All config data will be stored in ./data/ subdirectory
DOCKER_PROJECT_DIR=/opt/media-stack

# Container configs and runtime data (stored locally with compose files)
DOCKER_BASE_DIR=${DOCKER_PROJECT_DIR}/data

# Directory for SSD-based configs (faster storage for databases)
# Set this to a fast SSD path, or same as DOCKER_BASE_DIR if not needed
DOCKER_SSD_CONFIG_DIR=${DOCKER_PROJECT_DIR}/data

# Git-tracked configs directory (templates and static configs)
DOCKER_GIT_CONFIG_DIR=${DOCKER_PROJECT_DIR}/config-templates

# Media storage directory
DOCKER_MEDIA_DIR=/mnt/media

# Jellyfin media directory (defaults to DOCKER_MEDIA_DIR if not set)
# Set this if you want Jellyfin to use a different media location than other services
JELLYFIN_MEDIA_DIR=${DOCKER_MEDIA_DIR}

# Faster scratch/transcode paths for media servers
# Plex: set the Plex Transcoder temporary directory to /transcode in the Plex UI after first start
PLEX_TRANSCODE_DIR=${DOCKER_SSD_CONFIG_DIR}/plex-transcode
# Optional LAN URL Plex should advertise to local clients when bridge networking is in use
PLEX_ADVERTISE_IP=
# Jellyfin: optional public URL for autodiscovery and remote clients behind Pangolin/reverse proxies
JELLYFIN_PUBLISHED_SERVER_URL=
# Jellyfin stores transcodes under /config/transcodes by default; keep that path on faster storage
JELLYFIN_TRANSCODE_DIR=${DOCKER_SSD_CONFIG_DIR}/jellyfin-transcodes

# Backup destination directory for Duplicati (local disk, NAS mount, etc.)
BACKUP_DESTINATION=/mnt/backup

# Duplicati settings encryption key (generate with: openssl rand -hex 32)
# Strongly recommended if you back up `.env`
DUPLICATI_ENCRYPTION_KEY=

# =============================================================================
# VPN CONFIGURATION (Gluetun)
# =============================================================================

# VPN provider (mullvad, nordvpn, surfshark, etc.)
# See: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=mullvad

# OpenVPN credentials (provider-specific)
OPENVPN_USER=
OPENVPN_PASSWORD=

# Server regions (comma-separated)
SERVER_REGIONS=us

# =============================================================================
# TUNNEL SERVICES
# =============================================================================

# Pangolin/Newt tunnel credentials
PANGOLIN_ENDPOINT=https://pangolin.example.com
NEWT_ID=
NEWT_SECRET=

# Cloudflare Tunnel token (if using cloudflared)
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# OPTIONAL REVERSE PROXY SETTINGS
# =============================================================================

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Example basic-auth credentials for an optional reverse proxy dashboard
# (generate with: htpasswd -nb admin password)
# Default: admin:admin
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# =============================================================================
# IMMICH (Photo Management)
# =============================================================================

# Immich version tag
IMMICH_VERSION=release

# Storage locations
UPLOAD_LOCATION=/mnt/photos/upload
THUMB_LOCATION=/mnt/photos/thumbs
ENCODED_VIDEO_LOCATION=/mnt/photos/encoded-video
PROFILE_LOCATION=/mnt/photos/profile
BACKUP_LOCATION=/mnt/photos/backups

# Optional hardware group IDs for GPU/media acceleration
# Check with: getent group video && getent group render
VIDEO_GID=44
RENDER_GID=109

# Database settings
# Required before first start. Generate with: openssl rand -hex 32
DB_PASSWORD=
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/opt/docker-ssd/immich-postgres

# =============================================================================
# MONITORING (Grafana, Prometheus)
# =============================================================================

# Grafana admin credentials
# Required before first start. Generate with: openssl rand -hex 32
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Optional explicit Grafana root URL if it should differ from the Pangolin hostname
GRAFANA_ROOT_URL=https://${GRAFANA_SUBDOMAIN}.${DOMAIN_NAME}

# =============================================================================
# DOWNLOADERS
# =============================================================================

# Bitmagnet database password
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
BITMAGNET_POSTGRES_PASSWORD=

# TMDB API key (for Bitmagnet metadata)
# Get one at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# =============================================================================
# AUTOMATION (n8n)
# =============================================================================

# Pangolin/Newt hostnames for automation and file services
N8N_SUBDOMAIN=n8n
NEXTCLOUD_SUBDOMAIN=cloud
# Space-separated hostnames/IPs Nextcloud should trust for direct LAN access
NEXTCLOUD_TRUSTED_DOMAINS=${NEXTCLOUD_SUBDOMAIN}.${DOMAIN_NAME}

# =============================================================================
# COMMUNICATION (JITSI MEET)
# =============================================================================

# Pinned to the latest stable docker-jitsi-meet release reviewed for this repo on March 11, 2026.
JITSI_IMAGE_VERSION=stable-10655
JITSI_SUBDOMAIN=meet
JITSI_PUBLIC_URL=https://${JITSI_SUBDOMAIN}.${DOMAIN_NAME}
JITSI_MEDIA_SUBDOMAIN=rtc
JITSI_MEDIA_PUBLIC_HOSTNAME=${JITSI_MEDIA_SUBDOMAIN}.${DOMAIN_NAME}
JITSI_XMPP_DOMAIN=meet.jitsi
JITSI_XMPP_AUTH_DOMAIN=auth.${JITSI_XMPP_DOMAIN}
JITSI_XMPP_GUEST_DOMAIN=guest.${JITSI_XMPP_DOMAIN}
JITSI_XMPP_MUC_DOMAIN=muc.${JITSI_XMPP_DOMAIN}
JITSI_XMPP_INTERNAL_MUC_DOMAIN=internal-muc.${JITSI_XMPP_DOMAIN}
JITSI_AUTH_USER=owner
# Generated by `make init-env`. Use this when creating the moderator account with prosodyctl.
JITSI_AUTH_PASSWORD=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
JITSI_JICOFO_COMPONENT_SECRET=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
JITSI_JICOFO_AUTH_PASSWORD=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
JITSI_JVB_AUTH_PASSWORD=
JITSI_JVB_UDP_PORT=10000
# Use the DNS-only home media hostname so TURN and JVB stay off the VPS.
JITSI_TURN_HOST=${JITSI_MEDIA_PUBLIC_HOSTNAME}
JITSI_TURN_PORT=3478
JITSI_TURN_TRANSPORT=udp,tcp
JITSI_TURN_MIN_PORT=20000
JITSI_TURN_MAX_PORT=20100
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
# This is the coturn shared secret used by Jitsi XEP-0215 external services.
JITSI_TURN_CREDENTIALS=
# Required when using the `jitsi` profile. Cloudflare token with Zone DNS edit access for `${DOMAIN_NAME}`.
JITSI_CLOUDFLARE_API_TOKEN=

# =============================================================================
# PRODUCTIVITY
# =============================================================================

# Syncthing data root (defaults to a dedicated media subdirectory)
SYNCTHING_DATA_DIR=${DOCKER_MEDIA_DIR}/Sync

# Pangolin/Newt hostnames for app UIs
RADARR_SUBDOMAIN=radarr
SONARR_SUBDOMAIN=sonarr
LIDARR_SUBDOMAIN=lidarr
READARR_SUBDOMAIN=readarr
BAZARR_SUBDOMAIN=bazarr
WHISPARR_SUBDOMAIN=whisparr
QBITTORRENT_SUBDOMAIN=qbittorrent
PROWLARR_SUBDOMAIN=prowlarr
BITMAGNET_SUBDOMAIN=bitmagnet
PLEX_SUBDOMAIN=plex
JELLYFIN_SUBDOMAIN=jellyfin
STASH_SUBDOMAIN=stash
KAVITA_SUBDOMAIN=kavita
NAVIDROME_SUBDOMAIN=navidrome
TAUTULLI_SUBDOMAIN=tautulli
MAINTAINERR_SUBDOMAIN=maintainerr
TDARR_SUBDOMAIN=tdarr
PORTAINER_SUBDOMAIN=portainer
GLANCES_SUBDOMAIN=glances
GLANCE_SUBDOMAIN=glance
PROMETHEUS_SUBDOMAIN=prometheus
ALERTMANAGER_SUBDOMAIN=alertmanager
GRAFANA_SUBDOMAIN=grafana
UPTIME_KUMA_SUBDOMAIN=uptime
IMMICH_SUBDOMAIN=photos
OVERSEERR_SUBDOMAIN=overseerr
JELLYSEERR_SUBDOMAIN=jellyseerr
NOTIFIARR_SUBDOMAIN=notifiarr
HOMEPAGE_SUBDOMAIN=home
# Required before first start. Generate with: openssl rand -hex 32
# Keep this value when restoring or moving Homarr to a new server.
HOMARR_SECRET_ENCRYPTION_KEY=
SPEEDTEST_SUBDOMAIN=speedtest
SCRUTINY_SUBDOMAIN=scrutiny
DOZZLE_SUBDOMAIN=dozzle
FRESHRSS_SUBDOMAIN=freshrss
SEARXNG_SUBDOMAIN=search
# Optional explicit public URL for SearXNG. Useful when it is your default browser search engine away from home.
SEARXNG_BASE_URL=https://${SEARXNG_SUBDOMAIN}.${DOMAIN_NAME}
# Recommended before exposing SearXNG remotely. Generate with: openssl rand -hex 32
SEARXNG_SECRET=
# Disable this only if your reverse proxy does not forward real client IPs and searches get blocked with HTTP 429.
SEARXNG_LIMITER=true
# Keep `true` for Pangolin SSO protection. Set `false` only if you want seamless unauthenticated default-search usage from any device.
SEARXNG_PANGOLIN_SSO_ENABLED=true
SYNCTHING_SUBDOMAIN=syncthing
JOPLIN_SUBDOMAIN=joplin
KASM_SUBDOMAIN=kasm

# Joplin Server version tag
JOPLIN_VERSION=latest

# Joplin Server public base URL
# Set this to the same public URL Pangolin serves for Joplin
JOPLIN_BASE_URL=https://${JOPLIN_SUBDOMAIN}.${DOMAIN_NAME}

# Joplin PostgreSQL settings
JOPLIN_DB_NAME=joplin
JOPLIN_DB_USER=joplin
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
JOPLIN_DB_PASSWORD=
JOPLIN_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/joplin-postgres

# =============================================================================
# DOCUMENTS & KNOWLEDGE
# =============================================================================

PAPERLESS_SUBDOMAIN=paperless
PAPERLESS_URL=https://${PAPERLESS_SUBDOMAIN}.${DOMAIN_NAME}
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
PAPERLESS_DB_PASSWORD=
PAPERLESS_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/paperless-postgres
PAPERLESS_CONSUME_DIR=${DOCKER_MEDIA_DIR}/Documents/consume
PAPERLESS_OCR_LANGUAGE=eng
# Optional additional OCR language packs, separated by spaces.
# PAPERLESS_OCR_LANGUAGES=deu spa

STIRLING_SUBDOMAIN=pdf

KARAKEEP_SUBDOMAIN=karakeep
KARAKEEP_BASE_URL=https://${KARAKEEP_SUBDOMAIN}.${DOMAIN_NAME}
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
KARAKEEP_NEXTAUTH_SECRET=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
KARAKEEP_MEILI_MASTER_KEY=

DOCMOST_SUBDOMAIN=docs
DOCMOST_BASE_URL=https://${DOCMOST_SUBDOMAIN}.${DOMAIN_NAME}
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
DOCMOST_APP_SECRET=
# Required before first start because compose validates all included services. Generate with: openssl rand -hex 32
DOCMOST_DB_PASSWORD=
DOCMOST_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/docmost-postgres

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Watchtower notifications (shoutrrr format)
# See: https://containrrr.dev/shoutrrr/services/overview/
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=

# Notifiarr API key
NOTIFIARR_API_KEY=

# =============================================================================
# SPEEDTEST TRACKER
# =============================================================================

# Speedtest schedule (cron format) - default every 4 hours
# SPEEDTEST_SCHEDULE="0 */4 * * *"

# =============================================================================
# ADDITIONAL PROFILES
# =============================================================================
# Enable optional services with: docker compose --profile <name> up -d
#
# Available profiles:
#   monitoring    - Glances system monitor
#   dashboard     - Glance dashboard
#   arr           - *Arr apps plus downloader stack
#   downloaders   - Download services only
#   jellyfin      - Jellyfin + Jellyseerr
#   kavita        - Ebook/comic reader
#   stash         - Stash media organizer
#   tdarr         - Media transcoding
#   automation    - n8n workflow automation
#   jitsi         - Jitsi Meet private video calling
#   notifiarr     - Notification aggregator
#   restic        - Restic backup server
#   db-backup     - Database backup worker
#   files         - Nextcloud file sharing
#   scrutiny      - Disk S.M.A.R.T monitoring
#   speedtest     - Speedtest tracker
#   navidrome     - Music streaming
#   requests      - Overseerr request portal
#   maintainerr   - Automated media cleanup
