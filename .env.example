# .env.example - Copy this to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# -- Base directory for Docker appdata and downloads --
DOCKER_BASE_DIR=/mnt/local_disk_g/docker/media-stack
DOCKER_MEDIA_DIR=/mnt/media

# -- Homepage API Keys (obtain from each service) --
HOMEPAGE_VAR_RADARR_API_KEY=your_radarr_api_key_here
HOMEPAGE_VAR_SONARR_API_KEY=your_sonarr_api_key_here
HOMEPAGE_VAR_LIDARR_API_KEY=your_lidarr_api_key_here
HOMEPAGE_VAR_WHISPARR_API_KEY=your_whisparr_api_key_here
HOMEPAGE_VAR_BAZARR_API_KEY=your_bazarr_api_key_here
HOMEPAGE_VAR_QBITTORRENT_USER=your_qbittorrent_username
HOMEPAGE_VAR_QBITTORRENT_PASS=your_secure_qbittorrent_password
HOMEPAGE_VAR_PROWLARR_API_KEY=your_prowlarr_api_key_here
HOMEPAGE_VAR_JELLYFIN_API_KEY=your_jellyfin_api_key_here

# -- Gluetun VPN Configuration --
VPN_SERVICE_PROVIDER=your_vpn_provider
OPENVPN_USER=your_vpn_username
OPENVPN_PASSWORD=your_vpn_password
SERVER_REGIONS=Your_Preferred_Region

# -- Common User/Group IDs & Timezone --
PUID=1000
PGID=1000
TZ=Etc/UTC

# -- Cloudflare Configuration --
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# -- Domain Configuration --
DOMAIN_NAME=yourdomain.com

# -- Authelia Secrets (generate secure random strings) --
# Generate with: openssl rand -hex 32
AUTHELIA_SESSION_SECRET=generate_64_character_random_string
AUTHELIA_JWT_SECRET=generate_64_character_random_string
AUTHELIA_STORAGE_ENCRYPTION_KEY=generate_64_character_random_string

# -- Database Passwords --
# Generate secure passwords for any databases
# POSTGRES_PASSWORD=generate_secure_password_here
# MYSQL_ROOT_PASSWORD=generate_secure_password_here

# -- Additional Security Settings --
# TRUSTED_PROXIES=172.16.0.0/12
# ALLOWED_HOSTS=yourdomain.com,*.yourdomain.com