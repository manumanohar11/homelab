# ~/media-stack/.env.example
# Copy this file to .env and fill in your values
# Command: cp .env.example .env

# =============================================================================
# CORE SETTINGS
# =============================================================================

# User/Group IDs - Run 'id' to find your values
PUID=1000
PGID=1000

# Timezone - Find yours at https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Domain name for services (used for Traefik routing and labels)
DOMAIN_NAME=example.com

# =============================================================================
# DIRECTORY PATHS
# =============================================================================

# Base directory for this docker project (where docker-compose.yml lives)
# All config data will be stored in ./data/ subdirectory
DOCKER_PROJECT_DIR=/opt/media-stack

# Container configs and runtime data (stored locally with compose files)
DOCKER_BASE_DIR=${DOCKER_PROJECT_DIR}/data

# Directory for SSD-based configs (faster storage for databases)
# Set this to a fast SSD path, or same as DOCKER_BASE_DIR if not needed
DOCKER_SSD_CONFIG_DIR=${DOCKER_PROJECT_DIR}/data

# Git-tracked configs directory (templates and static configs)
DOCKER_GIT_CONFIG_DIR=${DOCKER_PROJECT_DIR}/config-templates

# Media storage directory
DOCKER_MEDIA_DIR=/mnt/media

# Jellyfin media directory (defaults to DOCKER_MEDIA_DIR if not set)
# Set this if you want Jellyfin to use a different media location than other services
JELLYFIN_MEDIA_DIR=${DOCKER_MEDIA_DIR}

# Backup destination directory
BACKUP_DESTINATION=/mnt/backup

# Duplicati settings encryption key (generate with: openssl rand -hex 32)
DUPLICATI_ENCRYPTION_KEY=

# =============================================================================
# VPN CONFIGURATION (Gluetun)
# =============================================================================

# VPN provider (mullvad, nordvpn, surfshark, etc.)
# See: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=mullvad

# OpenVPN credentials (provider-specific)
OPENVPN_USER=
OPENVPN_PASSWORD=

# Server regions (comma-separated)
SERVER_REGIONS=us

# =============================================================================
# TUNNEL SERVICES
# =============================================================================

# Pangolin/Newt tunnel credentials
PANGOLIN_ENDPOINT=https://pangolin.example.com
NEWT_ID=
NEWT_SECRET=

# Cloudflare Tunnel token (if using cloudflared)
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# REVERSE PROXY (Traefik)
# =============================================================================

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Traefik dashboard credentials (generate with: htpasswd -nb admin password)
# Default: admin:admin
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# =============================================================================
# IMMICH (Photo Management)
# =============================================================================

# Immich version tag
IMMICH_VERSION=release

# Storage locations
UPLOAD_LOCATION=/mnt/photos/upload
THUMB_LOCATION=/mnt/photos/thumbs
ENCODED_VIDEO_LOCATION=/mnt/photos/encoded-video
PROFILE_LOCATION=/mnt/photos/profile
BACKUP_LOCATION=/mnt/photos/backups

# Optional hardware group IDs for GPU/media acceleration
# Check with: getent group video && getent group render
VIDEO_GID=44
RENDER_GID=109

# Database settings
DB_PASSWORD=your_secure_password_here
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/opt/docker-ssd/immich-postgres

# =============================================================================
# MONITORING (Grafana, Prometheus)
# =============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# =============================================================================
# DOWNLOADERS
# =============================================================================

# Bitmagnet database password
BITMAGNET_POSTGRES_PASSWORD=your_secure_password_here

# TMDB API key (for Bitmagnet metadata)
# Get one at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# =============================================================================
# AUTOMATION (n8n)
# =============================================================================

# n8n subdomain
N8N_SUBDOMAIN=n8n

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Watchtower notifications (shoutrrr format)
# See: https://containrrr.dev/shoutrrr/services/overview/
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=

# Notifiarr API key
NOTIFIARR_API_KEY=

# =============================================================================
# API KEYS (for *Arr apps and Homepage widgets)
# =============================================================================

# These are typically auto-generated and found in each app's settings
# After services start, retrieve API keys from each app's settings page

# *Arr Suite API Keys
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=
READARR_API_KEY=
BAZARR_API_KEY=

# Plex API Key (X-Plex-Token)
# Find at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_API_KEY=

# Jellyfin API key (Dashboard > API Keys)
JELLYFIN_API_KEY=

# Overseerr API Key (Settings > General > API Key)
OVERSEERR_API_KEY=

# Immich API Key (Account Settings > API Keys)
IMMICH_API_KEY=

# Portainer API Key (Account > Access tokens)
PORTAINER_API_KEY=

# qBittorrent password (default: adminadmin, change in WebUI settings)
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=

# =============================================================================
# MEDIA EXTRAS (Tautulli, Navidrome)
# =============================================================================

# Tautulli API key (found in Tautulli Settings > Web Interface)
TAUTULLI_API_KEY=

# Navidrome credentials for Homepage widget
NAVIDROME_USER=admin
NAVIDROME_TOKEN=

# =============================================================================
# SPEEDTEST TRACKER
# =============================================================================

# Speedtest schedule (cron format) - default every 4 hours
# SPEEDTEST_SCHEDULE="0 */4 * * *"

# =============================================================================
# STIRLING PDF
# =============================================================================

# Enable security features (login required)
# STIRLING_SECURITY=false

# =============================================================================
# ADDITIONAL PROFILES
# =============================================================================
# Enable optional services with: docker compose --profile <name> up -d
#
# Available profiles:
#   monitoring    - Glances system monitor
#   dashboard     - Glance homepage
#   arr           - *Arr apps plus downloader stack
#   downloaders   - Download services only
#   jellyfin      - Jellyfin + Jellyseerr
#   kavita        - Ebook/comic reader
#   stash         - Stash media organizer
#   tdarr         - Media transcoding
#   automation    - n8n workflow automation
#   notifiarr     - Notification aggregator
#   restic        - Restic backup server
#   db-backup     - Database backup worker
#   files         - Nextcloud file sharing
#   scrutiny      - Disk S.M.A.R.T monitoring
#   speedtest     - Speedtest tracker
#   navidrome     - Music streaming
#   requests      - Overseerr request portal
#   maintainerr   - Automated media cleanup
