# /mnt/g/docker/.env.example
# Starter environment for the beginner path:
#   make init
#   docker compose up -d
#
# Optional bundles add their own variables from env/bundles/*.env.example.

# =============================================================================
# CORE HOST SETTINGS
# =============================================================================

# Run `id` and copy your user/group IDs.
PUID=1000
PGID=1000

# Set your local timezone.
TZ=America/New_York

# Base domain used by Pangolin/public-resource labels and optional reverse-proxy URLs.
DOMAIN_NAME=example.com

# Plex advertises this LAN address when host networking is in use.
LOCAL_LAN_IP=192.168.1.10

# =============================================================================
# DIRECTORIES
# =============================================================================

# Directory where this repository lives on the Docker host.
DOCKER_PROJECT_DIR=/opt/media-stack

# Container configs and runtime data.
DOCKER_BASE_DIR=${DOCKER_PROJECT_DIR}/data

# Faster storage for databases, caches, and transcodes.
DOCKER_SSD_CONFIG_DIR=${DOCKER_PROJECT_DIR}/data

# Git-tracked config templates used by optional bundles.
DOCKER_GIT_CONFIG_DIR=${DOCKER_PROJECT_DIR}/config-templates

# Main media library root.
DOCKER_MEDIA_DIR=/mnt/media

# Starter backup destination for Duplicati.
BACKUP_DESTINATION=/mnt/backup

# =============================================================================
# STARTER MEDIA
# =============================================================================

# Optional Plex claim token for first start.
PLEX_CLAIM=

# Optional Plex LAN advertise URL when bridge networking is used elsewhere.
PLEX_ADVERTISE_IP=

# Faster scratch path for Plex transcodes.
PLEX_TRANSCODE_DIR=${DOCKER_SSD_CONFIG_DIR}/plex-transcode

# Immich release tag.
IMMICH_VERSION=release

# Immich storage locations.
UPLOAD_LOCATION=/mnt/photos/upload
THUMB_LOCATION=/mnt/photos/thumbs
ENCODED_VIDEO_LOCATION=/mnt/photos/encoded-video
PROFILE_LOCATION=/mnt/photos/profile
BACKUP_LOCATION=/mnt/photos/backups

# Optional group IDs for media/GPU access.
VIDEO_GID=44
RENDER_GID=109

# Immich PostgreSQL settings.
DB_PASSWORD=
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/immich-postgres

# Linkwarden starter secrets.
LINKWARDEN_NEXTAUTH_SECRET=
LINKWARDEN_POSTGRES_PASSWORD=
LINKWARDEN_MEILI_MASTER_KEY=

# =============================================================================
# STARTER TOOLS
# =============================================================================

# Duplicati uses this to encrypt its settings database.
DUPLICATI_ENCRYPTION_KEY=

# Homarr uses this to decrypt stored secrets when you move the app between hosts.
HOMARR_SECRET_ENCRYPTION_KEY=
