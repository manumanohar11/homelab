        "options": {
          "body": "={\n  \"model\": \"nousresearch/nous-hermes-2-mixtral-8x7b-dpo\",\n  \"response\": { \"type\": \"json\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful fashion assistant. Your task is to create outfits. Respond ONLY with a JSON object in the format: { \\\"outfits\\\": [ { \\\"outfitName\\\": \\\"Outfit 1\\\", \\\"items\\\": [\\\"Item Name 1\\\", \\\"Item Name 2\\\"] } ] }. Do not include any explanations.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"My new clothing item is: {{$node['Airtable: Add New Item'].json.fields.Name}}. My entire wardrobe is: {{ $node['Airtable: Get All Wardrobe'].json.map(item => item.fields.Name).join(', ') }}. Please generate 3 stylish outfit combinations featuring my new item.\"\n    }\n  ]\n}"
        }
      },
