    {
      "parameters": {
        "subject": "New Item, Care Info & Virtual Try-On Ready!",
        "html": "=Your new item, <b>{{$node['Airtable: Add New Item'].json.fields.Name}}</b>, has been added.<br><hr>\n<b>Care Instructions:</b><br>\nMaterials: {{$node['Airtable: Add New Item'].json.fields.Materials}}<br>\nWashing: {{$node['Airtable: Add New Item'].json.fields.WashingInstructions}}<br><hr>\n<b>Outfit Suggestions & Virtual Try-Ons:</b><br>\n{{ $node['Merge VTON Results'].json.map(item => `\n  <div>\n    <h3>${item.json.outfitData.outfitName}</h3>\n    <p>${item.json.outfitData.items.join(', ')}</p>\n    <img src=\\\"https://drive.google.com/uc?id=${item.json.vtonImageId}\\\" width=\\\"300\\\" />\n  </div>\n`).join('') }}\n"
      },
      "name": "Send Email",
      "type": "n8n-nodes-base.sendEmail",
      "typeVersion": 2.1,
      "position": [
