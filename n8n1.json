      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "options": {
          "body": "={\n  \"model\": \"anthropic/claude-3-haiku-20240307\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"You are a fashion expert. Analyze this clothing item. Respond ONLY with a valid JSON object. The JSON should include: itemName, category, subCategory, color (as an array), pattern, style, and season (as an array). Do not include any text before or after the JSON object.\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"{{$node[\\\"Google Drive: Share Original Clothing\\\"].json[\\\"webViewLink\\\"]}}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"max_tokens\": 500\n}"
        }
      },
      "name": "HTTP Request: AI Clothing Analysis (Haiku)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        920,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_OPENROUTER_API_KEY_ID",
          "name": "OpenRouter API Key"
        }
      }
    },
