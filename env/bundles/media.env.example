# /mnt/g/docker/env/bundles/media.env.example
# Optional variables for the media bundle.
# Add them to .env with:
#   make init BUNDLES="media"

# Required for the media bundle if you enable VPN-routed services.
VPN_SERVICE_PROVIDER=mullvad
OPENVPN_USER=
OPENVPN_PASSWORD=
SERVER_REGIONS=us

# Optional Jellyfin overrides.
JELLYFIN_MEDIA_DIR=${DOCKER_MEDIA_DIR}
JELLYFIN_PUBLISHED_SERVER_URL=
JELLYFIN_TRANSCODE_DIR=${DOCKER_SSD_CONFIG_DIR}/jellyfin-transcodes

# Optional downloader and request-service integrations.
TMDB_API_KEY=
BITMAGNET_POSTGRES_PASSWORD=
NOTIFIARR_API_KEY=
