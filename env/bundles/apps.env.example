# /mnt/g/docker/env/bundles/apps.env.example
# Optional variables for the apps bundle.
# Add them to .env with:
#   make init BUNDLES="apps"

# Productivity apps.
SYNCTHING_DATA_DIR=${DOCKER_MEDIA_DIR}/Sync
SEARXNG_BASE_URL=https://search.${DOMAIN_NAME}
SEARXNG_SECRET=
SEARXNG_LIMITER=true
SEARXNG_PANGOLIN_SSO_ENABLED=true

JOPLIN_VERSION=latest
JOPLIN_BASE_URL=https://joplin.${DOMAIN_NAME}
JOPLIN_DB_NAME=joplin
JOPLIN_DB_USER=joplin
JOPLIN_DB_PASSWORD=
JOPLIN_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/joplin-postgres

# Documents and knowledge apps.
PAPERLESS_URL=https://paperless.${DOMAIN_NAME}
PAPERLESS_SECRET_KEY=
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USER=paperless
PAPERLESS_DB_PASSWORD=
PAPERLESS_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/paperless-postgres
PAPERLESS_CONSUME_DIR=${DOCKER_MEDIA_DIR}/Documents/consume
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_OCR_LANGUAGES=

KARAKEEP_VERSION=release
KARAKEEP_BASE_URL=https://karakeep.${DOMAIN_NAME}
KARAKEEP_NEXTAUTH_SECRET=
KARAKEEP_MEILI_MASTER_KEY=

DOCMOST_BASE_URL=https://docs.${DOMAIN_NAME}
DOCMOST_APP_SECRET=
DOCMOST_DB_NAME=docmost
DOCMOST_DB_USER=docmost
DOCMOST_DB_PASSWORD=
DOCMOST_DB_DATA_LOCATION=${DOCKER_SSD_CONFIG_DIR}/docmost-postgres

# File sharing and automation.
NEXTCLOUD_TRUSTED_DOMAINS=cloud.${DOMAIN_NAME}
