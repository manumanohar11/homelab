# /mnt/g/docker/env/bundles/ops.env.example
# Optional variables for the ops bundle.
# Add them to .env with:
#   make init BUNDLES="ops"

# Required before exposing Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://grafana.${DOMAIN_NAME}

# Optional Watchtower notifications.
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=
